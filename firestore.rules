rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function inWhitelist() {
      return exists(/databases/$(database)/documents/studentsWhitelist/$(request.auth.token.email));
    }

    match /studentsWhitelist/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }

    match /system/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /rankingCaches/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /questions/{questionId} {
      allow read: if true;
      allow write: if false;
    }

    match /students/{studentId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Firestore Session：取代 GAS loginStudent / verifySession
    // 每位學生只能寫自己的 session doc（doc ID = studentId）
    // 讀取：前端需要讀來比對 sessionId → 允許已登入者讀
    match /sessions/{studentId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if false;
    }

    match /answerDetails/{docId} {
      allow create: if signedIn() && inWhitelist() && request.resource.data.email == request.auth.token.email;
      allow read, update, delete: if false;
    }

    match /answerBatches/{docId} {
      allow create: if signedIn() && inWhitelist() && request.resource.data.email == request.auth.token.email;
      allow read: if signedIn() && inWhitelist() && resource.data.email == request.auth.token.email;
      allow update, delete: if false;
    }

    match /loginLogs/{docId} {
      allow create: if signedIn() && request.resource.data.email == request.auth.token.email;
      allow read, update, delete: if false;
    }

    match /questionStats/{questionId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if false;
    }

    match /studentStats/{studentId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if false;
    }
  }
}
